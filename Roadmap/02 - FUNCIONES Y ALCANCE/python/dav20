print("=" * 50)


def potencia(base, exponente=2):
    return base ** exponente


print(f"  potencia(5) = {potencia(5)}")         # Usa exponente=2 por defecto
print(f"  potencia(5, 3) = {potencia(5, 3)}")   # Usa exponente=3


