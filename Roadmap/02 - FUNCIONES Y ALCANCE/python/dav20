# 8. FUNCIONES DENTRO DE FUNCIONES (FUNCIONES ANIDADAS)
# -----------------------------------------------------------
print("" + "=" * 50)
print("FUNCIONES DENTRO DE FUNCIONES")
print("=" * 50)


def funcion_externa(texto):
    print(f"  Función externa recibe: '{texto}'")

    def funcion_interna():
        print(f"  Función interna accede a: '{texto}'")
        return texto.upper()

    resultado = funcion_interna()
    print(f"  Resultado de función interna: '{resultado}'")
    return resultado


funcion_externa("hola mundo")


# Closure (función que recuerda su entorno)
print("" + "=" * 50)
print("--- Closure ---")


def crear_multiplicador(factor):
    def multiplicar(numero):
        return numero * factor
    return multiplicar


doble = crear_multiplicador(2)
triple = crear_multiplicador(3)

print(f"  doble(5) = {doble(5)}")     # 10
print(f"  triple(5) = {triple(5)}")   # 15


