# DIFICULTAD EXTRA
# ============================================================
# Función que recibe dos cadenas de texto y retorna un número.
# Imprime números del 1 al 100:
# - Múltiplo de 3 → muestra primer parámetro
# - Múltiplo de 5 → muestra segundo parámetro
# - Múltiplo de 3 y 5 → muestra ambos concatenados
# - Retorna cuántas veces se imprimió el número (no texto)
# ============================================================
print("" + "=" * 50)
print("DIFICULTAD EXTRA - FIZZBUZZ PERSONALIZADO")
print("=" * 50)


def fizzbuzz_personalizado(texto_tres: str, texto_cinco: str) -> int:
    contador_numeros = 0

    for numero in range(1, 101):
        if numero % 3 == 0 and numero % 5 == 0:
            print(f"  {texto_tres}{texto_cinco}")
        elif numero % 3 == 0:
            print(f"  {texto_tres}")
        elif numero % 5 == 0:
            print(f"  {texto_cinco}")
        else:
            print(f"  {numero}")
            contador_numeros += 1

    return contador_numeros


# Ejecutar la función
veces_numero = fizzbuzz_personalizado("Fizz", "Buzz")
print(f"  El número se imprimió {veces_numero} veces (en lugar de texto).")

