# 7. FUNCIÓN CON ARGUMENTOS VARIABLES (*args y **kwargs)
# -----------------------------------------------------------
print("" + "=" * 50)
print("FUNCIÓN CON *args Y **kwargs")
print("=" * 50)


# *args - Número variable de argumentos posicionales
def sumar_todos(*args):
    print(f"  Argumentos recibidos: {args}")
    return sum(args)


print(f"  sumar_todos(1, 2, 3, 4, 5) = {sumar_todos(1, 2, 3, 4, 5)}")


# **kwargs - Número variable de argumentos con nombre
def mostrar_info(**kwargs):
    print("  Información recibida:")
    for clave, valor in kwargs.items():
        print(f"    {clave}: {valor}")


mostrar_info(nombre="David", lenguaje="Python", nivel="Intermedio")


