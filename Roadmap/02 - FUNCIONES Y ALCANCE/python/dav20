# 10. FUNCIONES YA CREADAS EN EL LENGUAJE (BUILT-IN)
# -----------------------------------------------------------
print("" + "=" * 50)
print("FUNCIONES BUILT-IN DE PYTHON")
print("=" * 50)

numeros = [34, 7, 23, 89, 12, 56, 1]

print(f"  Lista: {numeros}")
print(f"  len() → Longitud: {len(numeros)}")
print(f"  max() → Máximo: {max(numeros)}")
