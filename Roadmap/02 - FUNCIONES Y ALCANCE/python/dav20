print("" + "=" * 50)
print("VARIABLES LOCALES Y GLOBALES")
print("=" * 50)

# Variable global
variable_global = "Soy GLOBAL"


def funcion_local():
    # Variable local
    variable_local = "Soy LOCAL"
    print(f"  Dentro de la función:")
    print(f"    variable_local = '{variable_local}'")
    print(f"    variable_global = '{variable_global}'")  # Puede leer la global


funcion_local()
print(f"  Fuera de la función:")
print(f"    variable_global = '{variable_global}'")
# print(variable_local)  # ¡ERROR! No existe fuera de la función

# Modificar variable global dentro de una función
print("--- Modificar variable global con 'global' ---")

contador_global = 0


def incrementar():
    global contador_global
    contador_global += 1
    print(f"  Dentro de la función: contador_global = {contador_global}")


print(f"  Antes: contador_global = {contador_global}")
incrementar()
incrementar()
incrementar()
print(f"  Después: contador_global = {contador_global}")

# Variable con mismo nombre (local vs global)
print("--- Mismo nombre, diferente ámbito ---")

mensaje = "Soy la variable GLOBAL"


def demostrar_ambito():
    mensaje = "Soy la variable LOCAL"  # No afecta a la global
    print(f"  Dentro de la función: '{mensaje}'")


demostrar_ambito()
print(f"  Fuera de la función: '{mensaje}'")


