# map, filter, zip
print("--- map, filter, zip ---")
cuadrados = list(map(lambda x: x ** 2, [1, 2, 3, 4, 5]))
print(f"  map(cuadrado, [1,2,3,4,5]) = {cuadrados}")

pares = list(filter(lambda x: x % 2 == 0, [1, 2, 3, 4, 5, 6]))
print(f"  filter(pares, [1,2,3,4,5,6]) = {pares}")

nombres = ["Ana", "Luis", "María"]
edades = [25, 30, 28]
combinados = list(zip(nombres, edades))
print(f"  zip(nombres, edades) = {combinados}")


