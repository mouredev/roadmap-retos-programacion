# -----------------------------------------------------------
# 1. CONDICIONALES (if, elif, else)
# -----------------------------------------------------------
print("
" + "=" * 50)
print("ESTRUCTURAS CONDICIONALES")
print("=" * 50)

edad = 25

if edad < 18:
    print(f"Edad {edad}: Eres menor de edad")
elif edad >= 18 and edad < 65:
    print(f"Edad {edad}: Eres adulto")
else:
    print(f"Edad {edad}: Eres adulto mayor")

# Operador ternario
resultado = "Par" if edad % 2 == 0 else "Impar"
print(f"La edad {edad} es: {resultado}")

# Match (Python 3.10+)
print("
--- Match/Case (switch) ---")
dia = 3

match dia:
    case 1:
        print(f"Día {dia}: Lunes")
    case 2:
        print(f"Día {dia}: Martes")
    case 3:
        print(f"Día {dia}: Miércoles")
    case 4:
        print(f"Día {dia}: Jueves")
    case 5:
        print(f"Día {dia}: Viernes")
    case _:
        print(f"Día {dia}: Fin de semana")

