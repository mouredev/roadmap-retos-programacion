print("OPERADORES DE COMPARACIÓN")
print("=" * 50)

x = 10
y = 20

print(f"x = {x}, y = {y}")
print(f"Igual que: x == y → {x == y}")             # False
print(f"Diferente de: x != y → {x != y}")          # True
