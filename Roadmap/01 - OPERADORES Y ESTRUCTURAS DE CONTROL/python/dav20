# -----------------------------------------------------------
# 7. OPERADORES A NIVEL DE BITS (BITWISE)
# -----------------------------------------------------------
print("
" + "=" * 50)
print("OPERADORES A NIVEL DE BITS")
print("=" * 50)

m = 12  # En binario: 1100
n = 10  # En binario: 1010

print(f"m = {m} (binario: {bin(m)})")
print(f"n = {n} (binario: {bin(n)})")
print(f"AND bits: m & n = {m & n} (binario: {bin(m & n)})")     # 8  → 1000
print(f"OR bits: m | n = {m | n} (binario: {bin(m | n)})")      # 14 → 1110
print(f"XOR bits: m ^ n = {m ^ n} (binario: {bin(m ^ n)})")     # 6  → 0110
print(f"NOT bits: ~m = {~m} (binario: {bin(~m)})")              # -13
print(f"Desplazamiento izq: m << 2 = {m << 2}")                 # 48
print(f"Desplazamiento der: m >> 2 = {m >> 2}")                 # 3


