# 2. ESTRUCTURAS ITERATIVAS (bucles)
# -----------------------------------------------------------
print("
" + "=" * 50)
print("ESTRUCTURAS ITERATIVAS")
print("=" * 50)

# Bucle for
print("--- Bucle for ---")
for i in range(1, 6):
    print(f"  Iteración {i}")

# Bucle for con lista
print("
--- Bucle for con lista ---")
colores = ["rojo", "verde", "azul"]
for color in colores:
    print(f"  Color: {color}")

# Bucle while
print("
--- Bucle while ---")
contador = 0
while contador < 5:
    print(f"  Contador: {contador}")
    contador += 1

# Break y Continue
print("
--- Break ---")
for i in range(10):
    if i == 5:
        print(f"  Se detuvo en i = {i}")
        break
    print(f"  i = {i}")

print("
--- Continue ---")
for i in range(10):
    if i % 2 == 0:
        continue
    print(f"  Impar: {i}")

